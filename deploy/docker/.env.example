# 复制为 .env 后修改

# host-agent 接入 token
HOST_AGENT_BOOTSTRAP_TOKEN=your-secure-token-here

# Bifrost LLM Gateway（默认启用）
USE_BIFROST=true
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-xxx
# 多 key 轮转可选，逗号分隔
LLM_API_KEYS=
# OpenAI 兼容 API（vLLM / DeepSeek / Moonshot / Ollama）可选
LLM_BASE_URL=
LLM_COMPACT_MODEL=gpt-4o-mini
LLM_FALLBACK_PROVIDER=
LLM_FALLBACK_MODEL=
LLM_FALLBACK_API_KEY=

# Legacy Codex 认证 (三选一，保留用于回滚):
#
# 1. OpenAI API Key (最简单，推荐 Docker/服务器环境)
CODEX_API_KEY=sk-xxx
#
# 2. 挂载已有的 auth.json
#    先在本地 `codex login` 完成登录，然后:
#    docker run -v ~/.codex/auth.json:/data/codex-home/auth.json ...
#
# 3. 启动后通过前端 ChatGPT OAuth 登录 (需要配置 OAuth)
#    见 ai-server.env.example 中的 GPT_OAUTH_* 配置
