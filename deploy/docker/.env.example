# 复制为 .env 后修改

# host-agent 接入 token
HOST_AGENT_BOOTSTRAP_TOKEN=your-secure-token-here

# codex 认证 (三选一):
#
# 1. OpenAI API Key (最简单，推荐 Docker/服务器环境)
CODEX_API_KEY=sk-xxx
#
# 2. 挂载已有的 auth.json
#    先在本地 `codex login` 完成登录，然后:
#    docker run -v ~/.codex/auth.json:/data/codex-home/auth.json ...
#
# 3. 启动后通过前端 ChatGPT OAuth 登录 (需要配置 OAuth)
#    见 ai-server.env.example 中的 GPT_OAUTH_* 配置
