# ============================================================
# 基础配置
# ============================================================

HOST_AGENT_BOOTSTRAP_TOKEN=aiops-dev-token-2026

# ============================================================
# Bifrost LLM Gateway（默认启用）
# ============================================================
USE_BIFROST=true
LLM_PROVIDER=openai
LLM_MODEL=gpt-5.4
LLM_API_KEY=sk-AyLv6zsv7sZEHL7r6
LLM_API_KEYS=
LLM_BASE_URL=http://host.docker.internal:8317/v1
LLM_COMPACT_MODEL=gpt-5.4
LLM_FALLBACK_PROVIDER=
LLM_FALLBACK_MODEL=
LLM_FALLBACK_API_KEY=

# Legacy Codex runtime fallback（保留用于回滚）
CODEX_API_KEY=

# ============================================================
# Coroot 集成配置
# ============================================================

# Coroot 服务地址（必填，填写后启用 Coroot 集成）
# 示例: http://coroot.example.com:8080
COROOT_BASE_URL=

# Coroot API 认证令牌（推荐配置，完整集成所需）
COROOT_TOKEN=

# Coroot API 调用超时时间（默认 30s）
# 支持 Go duration 格式，如 10s、1m、500ms
COROOT_TIMEOUT=30s

# 数据源优先级策略（默认 coroot_first）
# 可选值: coroot_first（优先 Coroot）、local_first（优先本地）、coroot_only（仅 Coroot）
COROOT_PRIORITY=coroot_first

# 是否启用 Coroot 不可用时的降级回退（默认 true）
# 设为 false 时，Coroot 不可用将直接返回错误而不回退到本地数据源
COROOT_FALLBACK_ENABLED=true

# Coroot 健康检查间隔（默认 30s）
# 用于定期检测 Coroot 服务可用性
COROOT_HEALTH_CHECK_INTERVAL=30s

# 是否启用根因定位分析（RCA）引擎（默认 false）
# 当前开源版 Coroot 暂不支持 RCA，启用后将使用预留接口
COROOT_RCA_ENABLED=false
