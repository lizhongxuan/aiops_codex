AIOPS_HTTP_ADDR=0.0.0.0:8080
AIOPS_GRPC_ADDR=100.64.0.10:18090
DEFAULT_WORKSPACE=/data/workspace
APP_STATE_PATH=/data/ai-server-state.json
APP_AUDIT_LOG_PATH=/data/ai-audit.log

# Production security gate for remote host access.
HOST_AGENT_SECURITY_PROFILE=production
HOST_AGENT_BOOTSTRAP_TOKENS=rotate-2026-03,rotate-2026-02
HOST_AGENT_ALLOWED_HOST_IDS=linux-01,linux-02
HOST_AGENT_ALLOWED_CIDRS=100.64.0.0/10,10.0.0.0/8,192.168.0.0/16

# Required when HOST_AGENT_SECURITY_PROFILE=production.
AIOPS_GRPC_TLS_CERT_FILE=/certs/server.pem
AIOPS_GRPC_TLS_KEY_FILE=/certs/server-key.pem
AIOPS_GRPC_TLS_CLIENT_CA_FILE=/certs/ca.pem

# Optional frontend redirect when browser and ai-server are not on the same origin.
FRONTEND_REDIRECT_URL=https://aiops.internal.example/
