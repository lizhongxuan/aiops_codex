# Required: ai-server gRPC address that host-agent dials back to.
# Development only: `0.0.0.0:18090` is a temporary listen address for the server side,
# not a safe long-term exposure target. For production, use a private-network / VPN reachable
# hostname or IP and keep the port off the public internet.
AIOPS_SERVER_GRPC_ADDR=192.168.1.10:18090

# Required: stable host identity shown in the UI and used in approval/audit records.
# This value must stay fixed for the life of the machine. Do not reuse it across hosts,
# do not change it on reinstall/rotation, and do not treat AIOPS_AGENT_HOSTNAME as identity.
AIOPS_AGENT_HOST_ID=linux-01

# Required: human-readable hostname shown in Host Selector / terminal / approval cards.
AIOPS_AGENT_HOSTNAME=linux-01

# Optional: version label exposed by host-agent registration.
AIOPS_AGENT_VERSION=0.1.0

# Optional: free-form labels rendered in UI or audit tooling.
AIOPS_AGENT_LABELS=env=prod,region=sh,role=web

# Required: bootstrap token that must match ai-server HOST_AGENT_BOOTSTRAP_TOKEN(S).
# Production should rotate this token and keep it short-lived; do not leave a default token
# open on a long-lived 0.0.0.0:18090 deployment.
AIOPS_AGENT_BOOTSTRAP_TOKEN=replace-with-real-token

# Optional TLS / mTLS client settings when ai-server enables gRPC TLS.
# In production these settings are expected, not optional: use mTLS where possible and make
# sure the server cert SAN/CN matches AIOPS_AGENT_TLS_SERVER_NAME / the real access hostname.
# AIOPS_AGENT_TLS_CA_FILE=/certs/ca.pem
# AIOPS_AGENT_TLS_SERVER_NAME=aiops-server.internal
# AIOPS_AGENT_TLS_CERT_FILE=/certs/agent.pem
# AIOPS_AGENT_TLS_KEY_FILE=/certs/agent-key.pem
