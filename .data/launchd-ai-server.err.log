    return ''\n\n\ndef sample(pids):\n    out = {}\n    for pid in pids:\n        ru = RUsageInfoV2()\n        rc = libproc.proc_pid_rusage(pid, RUSAGE_INFO_V2, byref(ru))\n        if rc \"'!= 0:\n            continue\n        name = proc_name(pid) or f'\"'pid:{pid}'\n        out[pid] = {\n            'name': name,\n            'cpu_ns': int(ru.ri_user_time + ru.ri_system_time),\n            'mem_bytes': int(ru.ri_phys_footprint or ru.ri_resident_size),\n        }\n    return out\n\npids = list_pids()\nstart = sample(pids)\ninterval = 1.0\ntime.sleep(interval)\nend = sample(list(start.keys()))\nrows = []\nagg = {}\nfor pid, s in start.items():\n    e = end.get(pid)\n    if not e:\n        continue\n    delta_ns = e['cpu_ns'] - s['cpu_ns']\n    if delta_ns < 0:\n        continue\n    cpu_pct = delta_ns / 1e9 / interval * 100.0\n    mem_mb = e['mem_bytes'] / 1024 / 1024\n    name = e['name']\n    rows.append((cpu_pct, mem_mb, pid, name))\n    agg[name] = agg.get(name, 0.0) + cpu_pct\n\nrows.sort(reverse=True, key=lambda x: x[0])\nagg_rows = sorted(agg.items(), key=lambda x: x[1], reverse=True)\nprint('Top processes by CPU over ~1s sample:')\nfor cpu_pct, mem_mb, pid, name in rows[:12]:\n    if cpu_pct <= 0.1:\n        continue\n    print(f'{cpu_pct:6.1f}% cpu  {mem_mb:7.1f} MB  pid={pid:<6} {name}')\nprint('\\\\nTop programs aggregated by process name:')\nfor name, cpu_pct in agg_rows[:12]:\n    if cpu_pct <= 0.1:\n        continue\n    print(f'{cpu_pct:6.1f}% cpu  {name}')\nPY\""
