{"approvalId":"approval-39738e3338fe92a5","command":"/bin/zsh -lc \"python3 - \u003c\u003c'PY'\nimport ctypes\nfrom ctypes import c_int, c_void_p, c_uint32, create_string_buffer\nlibproc = ctypes.CDLL('/usr/lib/libproc.dylib')\nlibproc.proc_listallpids.argtypes = [c_void_p, c_int]\nlibproc.proc_listallpids.restype = c_int\nlibproc.proc_name.argtypes = [c_int, c_void_p, c_uint32]\nlibproc.proc_name.restype = c_int\nbufsize = 4096 * ctypes.sizeof(c_int)\nbuf = (c_int * 4096)()\ncount_bytes = libproc.proc_listallpids(buf, ctypes.sizeof(buf))\nprint('count_bytes', count_bytes)\ncount = count_bytes // ctypes.sizeof(c_int) if count_bytes \u003e 0 else 0\nshown = 0\nfor i in range(count):\n    pid = buf[i]\n    if pid \u003c= 0:\n        continue\n    name = create_string_buffer(1024)\n    n = libproc.proc_name(pid, name, 1024)\n    if n \u003e 0:\n        print(pid, name.value.decode(errors='ignore'))\n        shown += 1\n    if shown \u003e= 15:\n        break\nPY\"","cwd":"/Users/lizhongxuan/.aiops_codex","event":"approval.requested","hostId":"server-local","sessionId":"sess-2203add776c38e48","ts":"2026-03-25T09:34:48+08:00","type":"command"}
