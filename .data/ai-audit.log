{"approvalId":"approval-d3a48dd982a91a96","command":"/bin/zsh -lc \"python3 - \u003c\u003c'PY'\nimport ctypes, time, os\nfrom ctypes import c_int, c_void_p, c_uint32, c_uint64, c_uint8, POINTER, byref, create_string_buffer\n\nRUSAGE_INFO_V2 = 2\n\nclass RUsageInfoV2(ctypes.Structure):\n    _fields_ = [\n        ('ri_uuid', c_uint8 * 16),\n        ('ri_user_time', c_uint64),\n        ('ri_system_time', c_uint64),\n        ('ri_pkg_idle_wkups', c_uint64),\n        ('ri_interrupt_wkups', c_uint64),\n        ('ri_pageins', c_uint64),\n        ('ri_wired_size', c_uint64),\n        ('ri_resident_size', c_uint64),\n        ('ri_phys_footprint', c_uint64),\n        ('ri_proc_start_abstime', c_uint64),\n        ('ri_proc_exit_abstime', c_uint64),\n        ('ri_child_user_time', c_uint64),\n        ('ri_child_system_time', c_uint64),\n        ('ri_child_pkg_idle_wkups', c_uint64),\n        ('ri_child_interrupt_wkups', c_uint64),\n        ('ri_child_pageins', c_uint64),\n        ('ri_child_elapsed_abstime', c_uint64),\n        ('ri_diskio_bytesread', c_uint64),\n        ('ri_diskio_byteswritten', c_uint64),\n    ]\n\nlibproc = ctypes.CDLL('/usr/lib/libproc.dylib')\nlibproc.proc_listallpids.argtypes = [c_void_p, c_int]\nlibproc.proc_listallpids.restype = c_int\nlibproc.proc_name.argtypes = [c_int, c_void_p, c_uint32]\nlibproc.proc_name.restype = c_int\nlibproc.proc_pid_rusage.argtypes = [c_int, c_int, POINTER(RUsageInfoV2)]\nlibproc.proc_pid_rusage.restype = c_int\n\n\ndef list_pids(max_pids=16384):\n    buf = (c_int * max_pids)()\n    n = libproc.proc_listallpids(buf, ctypes.sizeof(buf))\n    count = n if n \u003e 0 else 0\n    # proc_listallpids returns number of pids, not bytes\n    return [buf[i] for i in range(min(count, max_pids)) if buf[i] \u003e 0]\n\n\ndef proc_name(pid):\n    buf = create_string_buffer(1024)\n    n = libproc.proc_name(pid, buf, 1024)\n    if n \u003e 0:\n        return buf.value.decode(errors='ignore')\n    return ''\n\n\ndef sample(pids):\n    out = {}\n    for pid in pids:\n        ru = RUsageInfoV2()\n        rc = libproc.proc_pid_rusage(pid, RUSAGE_INFO_V2, byref(ru))\n        if rc \"'!= 0:\n            continue\n        name = proc_name(pid) or f'\"'pid:{pid}'\n        out[pid] = {\n            'name': name,\n            'cpu_ns': int(ru.ri_user_time + ru.ri_system_time),\n            'mem_bytes': int(ru.ri_phys_footprint or ru.ri_resident_size),\n        }\n    return out\n\npids = list_pids()\nstart = sample(pids)\ninterval = 1.0\ntime.sleep(interval)\nend = sample(list(start.keys()))\nrows = []\nagg = {}\nfor pid, s in start.items():\n    e = end.get(pid)\n    if not e:\n        continue\n    delta_ns = e['cpu_ns'] - s['cpu_ns']\n    if delta_ns \u003c 0:\n        continue\n    cpu_pct = delta_ns / 1e9 / interval * 100.0\n    mem_mb = e['mem_bytes'] / 1024 / 1024\n    name = e['name']\n    rows.append((cpu_pct, mem_mb, pid, name))\n    agg[name] = agg.get(name, 0.0) + cpu_pct\n\nrows.sort(reverse=True, key=lambda x: x[0])\nagg_rows = sorted(agg.items(), key=lambda x: x[1], reverse=True)\nprint('Top processes by CPU over ~1s sample:')\nfor cpu_pct, mem_mb, pid, name in rows[:12]:\n    if cpu_pct \u003c= 0.1:\n        continue\n    print(f'{cpu_pct:6.1f}% cpu  {mem_mb:7.1f} MB  pid={pid:\u003c6} {name}')\nprint('\\\\nTop programs aggregated by process name:')\nfor name, cpu_pct in agg_rows[:12]:\n    if cpu_pct \u003c= 0.1:\n        continue\n    print(f'{cpu_pct:6.1f}% cpu  {name}')\nPY\"","cwd":"/Users/lizhongxuan/.aiops_codex","event":"approval.requested","hostId":"server-local","sessionId":"sess-2203add776c38e48","ts":"2026-03-25T09:35:58+08:00","type":"command"}
