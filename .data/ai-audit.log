yref(ru)) \"'!= 0:\n            continue\n        out[pid] = (proc_name(pid) or f'\"'pid:{pid}', int(ru.ri_user_time + ru.ri_system_time), int(ru.ri_phys_footprint or ru.ri_resident_size))\n    return out\npids = list_pids()\na = snap(pids)\ninterval = 3.0\ntime.sleep(interval)\nb = snap(list(a.keys()))\nrows = []\nfor pid, (name, t0, mem0) in a.items():\n    if pid not in b:\n        continue\n    name2, t1, mem1 = b[pid]\n    cpu = (t1 - t0) / 1e9 / interval * 100.0\n    if cpu \u003e 0.05:\n        rows.append((cpu, mem1 / 1024 / 1024, pid, name2))\nrows.sort(reverse=True)\nfor cpu, mem, pid, name in rows[:10]:\n    print(f'{cpu:5.1f}% cpu  {mem:7.1f} MB  pid={pid:\u003c6} {name}')\nPY\"","cwd":"/Users/lizhongxuan/.aiops_codex","event":"approval.requested","hostId":"server-local","sessionId":"sess-2203add776c38e48","ts":"2026-03-25T09:36:25+08:00","type":"command"}
